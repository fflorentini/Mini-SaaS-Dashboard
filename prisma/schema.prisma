generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id             String   @id @default(uuid())
  name           String
  status         String
  deadline       DateTime
  assignedMember String
  budget         Float

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}